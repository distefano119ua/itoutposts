[1255.710124, "o", "\u001b[0;32mok: [private]\u001b[0m\r\n"]
[1255.713214, "o", "\r\nTASK [Stop all running Docker containers] ***********************************************************************************************\r\n"]
[1259.903824, "o", "\u001b[0;33mchanged: [private]\u001b[0m\r\n"]
[1263.32663, "o", "\u001b[0;33mchanged: [public]\u001b[0m\r\n"]
