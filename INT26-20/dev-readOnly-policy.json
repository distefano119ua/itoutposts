{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListDevBuckets",
            "Effect": "Allow",
            "Action": "s3:ListBucket",
            "Resource": "arn:aws:s3:::dev-*"
        },
        {
            "Sid": "ReadObjectsFromDevBuckets",
            "Effect": "Allow",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::dev-*/*"
        }
    ]
}